# Local Codex runtime state and transient files
.tmp/
.codex-cli-home/
.codex-sdk-home/

# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Node/frontend dependencies and generated build output
node_modules/
frontend/**/node_modules/
frontend/**/dist/

# V4 generation cache: keep versioned guide briefs, ignore per-persona transient synthesis payloads
data/personas/.v4_generation/*
!data/personas/.v4_generation/guides/
!data/personas/.v4_generation/guides/**

# V5 generation cache: keep versioned guide briefs, ignore per-persona transient synthesis payloads
data/personas/.v5_generation/*
!data/personas/.v5_generation/guides/
!data/personas/.v5_generation/guides/**
